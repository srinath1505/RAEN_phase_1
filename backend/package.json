{
  "name": "raen-backend",
  "version": "1.0.0",
  "description": "RAEN E-commerce Backend API",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate --schema=./src/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=./src/prisma/schema.prisma",
    "prisma:migrate:prod": "prisma migrate deploy --schema=./src/prisma/schema.prisma",
    "prisma:seed": "node src/prisma/seed.js",
    "prisma:studio": "prisma studio --schema=./src/prisma/schema.prisma",
    "test": "jest --coverage"
  },
  "keywords": [
    "ecommerce",
    "raen",
    "fashion",
    "luxury"
  ],
  "author": "RAEN",
  "license": "ISC",
  "dependencies": {
    "@paypal/checkout-server-sdk": "^1.0.3",
    "@prisma/client": "^5.7.1",
    "@sendgrid/mail": "^8.1.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.7",
    "razorpay": "^2.9.2",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prisma": "^5.7.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
