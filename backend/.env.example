# RAEN Backend Environment Variables

NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/raen_db

# JWT
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Admin
ADMIN_EMAIL=admin@raen.design
ADMIN_PASSWORD=RaenAdmin2024!

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_ENV=sandbox

# UPI
UPI_ID=yourupiid@bank
UPI_MERCHANT_NAME=RAEN
UPI_PAYMENT_NOTE=RAEN Order Payment

# Email
EMAIL_PROVIDER=nodemailer
SENDGRID_API_KEY=your_sendgrid_api_key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=hello@raen.design
SUPPORT_EMAIL=hello@raen.design

# Pricing
TAX_RATE=0.00
SHIPPING_FLAT_RATE=0
CURRENCY=EUR
