# RAEN Backend — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.

NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:4173

# Database — Neon PostgreSQL (or any PostgreSQL instance)
DATABASE_URL=postgresql://username:password@host:5432/dbname?sslmode=require

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-char-random-hex-string
JWT_EXPIRES_IN=7d

# Admin seed credentials (used by prisma:seed to create the first admin user)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=replace-with-strong-password

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# PayPal — set PAYPAL_ENV=production for live keys
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_ENV=sandbox
# Get from PayPal Developer Dashboard → My Apps → Webhooks → copy Webhook ID
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

# UPI
UPI_ID=yourupiid@bank
UPI_MERCHANT_NAME=RAEN
UPI_PAYMENT_NOTE=RAEN Order Payment

# Email — Hostinger SMTP (or any SMTP provider)
EMAIL_PROVIDER=nodemailer
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=hello@yourdomain.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=hello@yourdomain.com
SUPPORT_EMAIL=hello@yourdomain.com

# Pricing
TAX_RATE=0.00
SHIPPING_FLAT_RATE=0
CURRENCY=EUR

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Twilio SMS/WhatsApp OTP
# TWILIO_PHONE_NUMBER must be a number purchased from twilio.com (not a personal number)
# TWILIO_WHATSAPP_NUMBER: use whatsapp:+14155238886 for sandbox, or your approved WA business number
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Token store backend: memory (dev) | db (recommended) | redis (production scale-out)
TOKEN_STORE=db
# Only required when TOKEN_STORE=redis
REDIS_URL=redis://localhost:6379
